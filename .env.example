# Copier vers .env.local et remplir avec les valeurs du tableau de bord Supabase (Settings -> API).
# Format recommande Nuxt:
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Compat (fallback):
SUPABASE_URL=
SUPABASE_KEY=

# Serveur uniquement (ne jamais exposer côté client)
# Prefixe Nuxt recommandé pour runtimeConfig privé:
NUXT_SUPABASE_SERVICE_ROLE_KEY=
# Compat:
SUPABASE_SERVICE_ROLE_KEY=
